{
  "manifest_version": 3,
  "name": "Catsnip",
  "version": "1.0.0",
  "description": "Snip any region — inside or outside the browser — then crop, annotate, OCR, copy, and save. Everything stays on your device.",
  "author": "artfred16",
  "homepage_url": "https://artfred16.github.io",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "desktopCapture",
    "downloads",
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Catsnip",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "commands": {
    "snip-region": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Snip a region of the current page"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
